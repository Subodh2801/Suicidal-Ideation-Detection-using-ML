# Environment template — Sai Subodh
# Copy to ".env", fill values, never commit ".env" (see README).

# Random string for Flask sessions (generate one: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=

# Optional: Gmail SMTP for signup OTP (use an app password, not your normal password)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587

# Set to 1 only while developing locally
FLASK_DEBUG=0

# Path to Suicide_Detection.csv if not in default location
SUICIDE_DATASET_PATH=Dataset/Suicide_Detection.csv
